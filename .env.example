# Supabase project URL and anon (public) key - safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - SERVER-ONLY, never expose to the browser.
# Not currently used at runtime (this app is a static export with no
# server), kept here for future use if a serverless function is added.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
